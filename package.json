{
    "name": "@axonyx/react",
    "version": "0.0.26",
    "description": "React wrappers for Axonyx UI Foundry components.",
    "license": "MIT",
    "homepage": "https://axonyx.dev",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "*.css"
    ],
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/client.ts src/icons.tsx --format esm,cjs --dts --external react --external react-dom --external @axonyx/ui",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "@axonyx/ui": ">=0.0.1",
        "react": ">=18",
        "react-dom": ">=18"
    },
    "devDependencies": {
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "tsup": "^8.3.5",
        "typescript": "^5.6.3"
    },
    "keywords": [
        "axonyx",
        "react",
        "nextjs",
        "design-system",
        "foundry",
        "ui"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vladanPro/axonyx-react.git"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "import": "./dist/client.js",
            "require": "./dist/client.cjs"
        },
        "./icons": {
            "types": "./dist/icons.d.ts",
            "import": "./dist/icons.js",
            "require": "./dist/icons.cjs"
        }
    }
}
