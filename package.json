{
  "name": "@axonyx/react",
  "version": "0.0.2",
  "description": "React wrappers for Axonyx UI Foundry components.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external react-dom --external @axonyx/ui",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@axonyx/ui": ">=0.0.1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "axonyx",
    "react",
    "nextjs",
    "design-system",
    "foundry",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladanPro/axonyx-react.git"
  }
}
